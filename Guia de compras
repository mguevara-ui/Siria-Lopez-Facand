<!DOCTYPE html>
<html lang="es-CL">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Compras en el supermercado · Siria López Nutrición</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --purple: #240054;
    --purple-600: #4A2585;
    --purple-300: #8E6FC4;
    --magenta: #E1017A;
    --magenta-soft: #F255A1;
    --cream: #FBF7F4;
    --cream-2: #F4ECF3;
    --ink: #271240;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--cream);
    color: var(--ink);
    font-family: 'Inter', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  ::selection { background: var(--magenta); color: #fff; }

  .wrap { max-width: 1160px; margin: 0 auto; padding-left: 22px; padding-right: 22px; }

  /* ---------- Header ---------- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(28, 4, 64, 0.9);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255, 255, 255, .08);
  }

  .site-header .wrap {
    padding-top: 14px;
    padding-bottom: 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .logo .logo-name {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 600;
    font-size: 24px;
    color: #fff;
    letter-spacing: .01em;
  }

  .logo .logo-sub {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 9px;
    letter-spacing: .34em;
    text-transform: uppercase;
    color: var(--magenta-soft);
    margin-top: 3px;
  }

  .header-actions { display: flex; align-items: center; gap: 10px; }

  .btn-ghost {
    background: transparent;
    border: 0;
    color: rgba(255, 255, 255, .78);
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 14px;
    cursor: pointer;
    padding: 9px 12px;
    border-radius: 99px;
    transition: color .2s ease, background .2s ease;
  }

  .btn-ghost:hover { color: #fff; background: rgba(255, 255, 255, .08); }

  .btn-print {
    background: var(--magenta);
    border: 0;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 13.5px;
    cursor: pointer;
    padding: 11px 20px;
    border-radius: 99px;
    box-shadow: 0 8px 22px rgba(225, 1, 122, .34);
    transition: background .2s ease, box-shadow .2s ease;
  }

  .btn-print:hover {
    background: var(--magenta-soft);
    box-shadow: 0 10px 26px rgba(225, 1, 122, .42);
  }

  /* ---------- Print-only title ---------- */
  .print-title { display: none; }

  /* ---------- Hero ---------- */
  .hero {
    position: relative;
    overflow: hidden;
    background: radial-gradient(120% 100% at 50% -20%, #38146F 0%, #260A57 45%, #1B0440 100%);
    color: #fff;
  }

  .hero-glow-1,
  .hero-glow-2 {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-glow-1 {
    top: -140px;
    right: -120px;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, rgba(225, 1, 122, .55), transparent 68%);
    filter: blur(50px);
  }

  .hero-glow-2 {
    bottom: -180px;
    left: -140px;
    width: 460px;
    height: 460px;
    background: radial-gradient(circle, rgba(142, 111, 196, .5), transparent 68%);
    filter: blur(60px);
  }

  .hero-inner {
    position: relative;
    padding: 78px 22px 82px;
  }

  .eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: .24em;
    text-transform: uppercase;
    color: var(--magenta-soft);
    margin-bottom: 22px;
  }

  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: clamp(2.4rem, 7vw, 4.4rem);
    line-height: 1.02;
    margin: 0;
    letter-spacing: -.01em;
    max-width: 16ch;
  }

  .hero h1 i {
    font-weight: 600;
    color: var(--magenta-soft);
    font-style: italic;
  }

  .hero-sub {
    margin: 26px 0 0;
    max-width: 62ch;
    font-size: clamp(1rem, 2.4vw, 1.18rem);
    line-height: 1.65;
    font-weight: 300;
    color: rgba(255, 255, 255, .82);
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 32px;
  }

  .tag-glass {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #fff;
    background: rgba(255, 255, 255, .10);
    border: 1px solid rgba(255, 255, 255, .18);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 8px 16px;
    border-radius: 99px;
  }

  /* ---------- Categories section ---------- */
  .cat-section {
    background: var(--cream);
    padding: clamp(40px, 7vw, 72px) 22px clamp(56px, 8vw, 96px);
  }

  .cat-header {
    text-align: center;
    max-width: 60ch;
    margin: 0 auto 6px;
  }

  .cat-header .eyebrow { color: var(--magenta); }

  .cat-header h2 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: clamp(1.9rem, 4.4vw, 2.9rem);
    line-height: 1.06;
    margin: 0;
    color: var(--purple);
  }

  .cat-header h2 i { font-weight: 600; font-style: italic; }

  /* ---------- Chips ---------- */
  .chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin: 30px auto clamp(34px, 5vw, 48px);
    max-width: 820px;
  }

  .chip {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 13px;
    padding: 10px 18px;
    border-radius: 99px;
    cursor: pointer;
    transition: all .2s ease;
    background: #fff;
    color: var(--purple-600);
    border: 1px solid rgba(36, 0, 84, .14);
  }

  .chip:hover {
    border-color: var(--magenta-soft);
    color: var(--magenta);
  }

  .chip.is-active {
    background: var(--purple);
    color: #fff;
    border: 1px solid var(--purple);
    font-weight: 600;
    box-shadow: 0 8px 20px rgba(36, 0, 84, .26);
  }

  .chip.is-active:hover {
    border-color: var(--purple);
    color: #fff;
  }

  /* ---------- Grid & cards ---------- */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 22px;
    align-items: start;
  }

  .glass-card {
    background: rgba(255, 255, 255, .72);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 22px;
    border-top: 3px solid var(--card-color, var(--purple-600));
    box-shadow: 0 14px 40px rgba(36, 0, 84, .09);
    padding: 26px 24px 12px;
  }

  .card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 18px;
  }

  .card-head h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-size: 1.62rem;
    line-height: 1.08;
    margin: 0;
    color: var(--card-color, var(--purple-600));
    max-width: 11ch;
    overflow-wrap: break-word;
  }

  .macro-tag {
    flex: none;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 9.5px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--tag-color, var(--purple-600));
    background: var(--tag-tint, rgba(74, 37, 133, .10));
    padding: 6px 11px;
    border-radius: 99px;
    white-space: nowrap;
  }

  .food-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 14px;
    padding: 11px 0;
    border-bottom: 1px solid rgba(36, 0, 84, .08);
  }

  .food-row:last-child { border-bottom: none; }

  .food-row .food-name {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 14.5px;
    color: var(--ink);
    line-height: 1.35;
  }

  .food-row .food-tip {
    flex: none;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 12px;
    color: rgba(39, 18, 64, .5);
    font-variant-numeric: tabular-nums;
    text-align: right;
    white-space: nowrap;
  }

  /* ---------- Callout ---------- */
  .callout {
    margin-top: 26px;
    background: linear-gradient(135deg, rgba(142, 111, 196, .14), rgba(225, 1, 122, .08));
    border: 1px solid rgba(142, 111, 196, .28);
    border-radius: 22px;
    padding: clamp(24px, 4vw, 34px) clamp(24px, 4vw, 38px);
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .callout-quote {
    flex: none;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 600;
    font-size: 52px;
    line-height: .7;
    color: var(--purple-300);
  }

  .callout-eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 10px;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--magenta);
    margin-bottom: 10px;
  }

  .callout p {
    margin: 0;
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.2vw, 1.14rem);
    line-height: 1.6;
    color: var(--purple);
    max-width: 64ch;
  }

  .callout p i {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 600;
  }

  /* ---------- Footer ---------- */
  .site-footer {
    background: var(--purple);
    color: #fff;
    padding: clamp(38px, 6vw, 58px) 22px;
  }

  .site-footer .wrap {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .footer-right {
    text-align: right;
    font-family: 'Inter', sans-serif;
    font-size: 13.5px;
    line-height: 1.7;
    color: rgba(255, 255, 255, .72);
  }

  .footer-right .footer-tagline {
    font-style: italic;
    font-family: 'Cormorant Garamond', serif;
    font-size: 17px;
    color: #fff;
  }

  /* ---------- Reveal animation ---------- */
  [data-reveal] {
    opacity: 0;
    filter: blur(16px);
    transform: translateY(30px);
    transition: opacity .7s ease, filter .7s ease, transform .8s cubic-bezier(.2, .7, .2, 1);
    will-change: opacity, filter, transform;
  }

  [data-reveal].is-visible {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      filter: none;
      transform: none;
      transition: none;
    }
  }

  /* ---------- Print ---------- */
  @media print {
    .no-print { display: none !important; }
    body { background: #fff; }
    .print-title { display: block !important; }
    .hero { display: none !important; }
    [data-reveal] {
      opacity: 1 !important;
      filter: none !important;
      transform: none !important;
    }
    .glass-card {
      box-shadow: none !important;
      border: 1px solid #e4dced !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
      break-inside: avoid;
    }
    .cat-section { background: #fff !important; }
  }
</style>
</head>
<body>

<header class="site-header no-print">
  <div class="wrap">
    <div class="logo">
      <span class="logo-name">Siria López</span>
      <span class="logo-sub">Nutrición</span>
    </div>
    <div class="header-actions">
      <button type="button" class="btn-ghost" id="btn-back">← Volver</button>
      <button type="button" class="btn-print" id="btn-print">Descargar / Imprimir</button>
    </div>
  </div>
</header>

<div class="print-title wrap">
  <div class="eyebrow" style="color:var(--magenta);margin-bottom:6px;">Recurso · Siria López Nutrición</div>
  <div style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:34px;color:var(--purple);">Compras en el <i>supermercado</i></div>
</div>

<section class="hero">
  <div class="hero-glow-1" aria-hidden="true"></div>
  <div class="hero-glow-2" aria-hidden="true"></div>
  <div class="hero-inner wrap">
    <div class="eyebrow" data-reveal>Recurso · Siria López Nutrición</div>
    <h1 data-reveal>Compras en el <i>supermercado</i></h1>
    <p class="hero-sub" data-reveal>Una guía de productos reales que recomiendo para llenar el carro sin complicarte, ordenados por categoría. Porque comer bien no empieza en la cocina: también se decide en la góndola.</p>
    <div class="hero-tags" data-reveal>
      <span class="tag-glass">Pan</span>
      <span class="tag-glass">Lácteos</span>
      <span class="tag-glass">Cereales</span>
      <span class="tag-glass">Dulce sin azúcar</span>
    </div>
  </div>
</section>

<section class="cat-section">
  <div class="wrap">

    <div class="cat-header" data-reveal>
      <div class="eyebrow">Por categoría</div>
      <h2>Filtra y arma tu <i>carro ideal</i></h2>
    </div>

    <div class="chips no-print" id="chips" role="group" aria-label="Filtrar por categoría"></div>

    <div class="cards-grid" id="cards-grid"></div>

    <div class="callout" id="callout" data-reveal>
      <div class="callout-quote" aria-hidden="true">”</div>
      <div>
        <div class="callout-eyebrow">Nota de la nutricionista</div>
        <p>Los alimentos sin azúcar no son del todo saludables: son una opción <i>de vez en cuando</i> para no exceder el consumo de sacarosa (azúcar).</p>
      </div>
    </div>

  </div>
</section>

<footer class="site-footer">
  <div class="wrap">
    <div class="logo">
      <span class="logo-name" style="font-size:26px;">Siria López</span>
      <span class="logo-sub" style="margin-top:4px;">Nutrición</span>
    </div>
    <div class="footer-right">
      <div class="footer-tagline">No es una dieta, es un estilo de vida</div>
      <div>lanutridelasgirls@sirialopez.cl</div>
    </div>
  </div>
</footer>

<script>
(function () {
  var CARDS = [
    {
      category: 'pan', title: 'Pan integral', macroTag: 'Elige integral',
      color: '#4A2585', tint: 'rgba(74,37,133,.10)', tag: '#4A2585',
      items: [
        { name: 'Marraqueta a granel', tip: 'pide integral' },
        { name: 'Pan molde integral', tip: 'revisa fibra' },
        { name: 'Pan pita', tip: 'porción justa' },
        { name: 'Ideal Linaza y Chía', tip: '+semillas' },
        { name: 'Fuchs Integral', tip: 'masa densa' },
        { name: 'Castaño Linaza Chía', tip: '650 g' },
        { name: 'Castaño Multigrano', tip: 'con prebióticos' },
        { name: 'Castaño Integral Multigrano', tip: '400 g' },
        { name: 'Castaño Integral Familiar', tip: '630 g' }
      ]
    },
    {
      category: 'lacteos', title: 'Lácteos protein', macroTag: 'Descremado o protein',
      color: '#E1017A', tint: 'rgba(225,1,122,.10)', tag: '#C1006A',
      items: [
        { name: 'Colun Sin Azúcar', tip: '0% azúcar' },
        { name: 'Leche Protein (Colun/Soprole/Loncoleche)', tip: '+proteína' },
        { name: 'Yogur protein Soprole/Colun', tip: 'sin azúcar' },
        { name: 'Batido protein', tip: 'post-entreno' },
        { name: 'Quillayes Griego Natural', tip: '140 g' },
        { name: 'Yogur descremado sin azúcar', tip: 'diario' }
      ]
    },
    {
      category: 'cereales', title: 'Cereales', macroTag: 'Sin azúcar añadida',
      color: '#4A2585', tint: 'rgba(74,37,133,.10)', tag: '#4A2585',
      items: [
        { name: 'Granola Tika', tip: 'sin azúcar' },
        { name: 'Vivo Line', tip: 'con avena' },
        { name: 'Tika Avena-Quinoa con semillas', tip: '+semillas' },
        { name: 'Granola frutos rojos', tip: 'porción ¼ taza' },
        { name: 'Barra Soul Bar', tip: 'snack' }
      ]
    },
    {
      category: 'acomp', title: 'Acompañamiento dulce', macroTag: '0% azúcar',
      color: '#8E6FC4', tint: 'rgba(142,111,196,.14)', tag: '#6B4EA0',
      items: [
        { name: "Watt's Mermelada 0% azúcar", tip: '200 g' },
        { name: 'Daily Manjar sin azúcar', tip: 'cucharadita' },
        { name: 'Colun Mi Dulce', tip: 'sin azúcar' },
        { name: 'Maple syrup sin azúcar', tip: 'topping' },
        { name: 'Salsa de chocolate sin azúcar', tip: 'con moderación' }
      ]
    },
    {
      category: 'antojo', title: 'Antojo dulce', macroTag: 'De vez en cuando',
      color: '#8E6FC4', tint: 'rgba(142,111,196,.14)', tag: '#6B4EA0',
      items: [
        { name: 'Brownie sin azúcar', tip: '1 porción' },
        { name: 'Galletas Mizos sin lactosa', tip: 'sin lactosa' },
        { name: 'Barra Zero', tip: 'sin lactosa' },
        { name: 'EcoVida sin gluten chocolate chip', tip: 'sin gluten' }
      ]
    }
  ];

  var CHIP_DEFS = [
    { key: 'todas', label: 'Todas' },
    { key: 'pan', label: 'Pan integral' },
    { key: 'lacteos', label: 'Lácteos protein' },
    { key: 'cereales', label: 'Cereales' },
    { key: 'acomp', label: 'Acompañamiento dulce' },
    { key: 'antojo', label: 'Antojo dulce' }
  ];

  var CALLOUT_FILTERS = ['todas', 'acomp', 'antojo'];

  var state = { filter: 'todas' };

  var chipsEl = document.getElementById('chips');
  var gridEl = document.getElementById('cards-grid');
  var calloutEl = document.getElementById('callout');

  function escapeHtml(str) {
    return String(str).replace(/[&<>"']/g, function (ch) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch];
    });
  }

  function renderChips() {
    chipsEl.innerHTML = '';
    CHIP_DEFS.forEach(function (chip) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'chip' + (chip.key === state.filter ? ' is-active' : '');
      btn.textContent = chip.label;
      btn.addEventListener('click', function () {
        state.filter = chip.key;
        render();
      });
      chipsEl.appendChild(btn);
    });
  }

  function renderCards() {
    var visible = state.filter === 'todas'
      ? CARDS
      : CARDS.filter(function (c) { return c.category === state.filter; });

    gridEl.innerHTML = visible.map(function (card) {
      var rows = card.items.map(function (item) {
        return (
          '<div class="food-row">' +
            '<span class="food-name">' + escapeHtml(item.name) + '</span>' +
            '<span class="food-tip">' + escapeHtml(item.tip) + '</span>' +
          '</div>'
        );
      }).join('');

      return (
        '<article class="glass-card" data-reveal style="--card-color:' + card.color + ';">' +
          '<div class="card-head">' +
            '<h3>' + escapeHtml(card.title) + '</h3>' +
            '<span class="macro-tag" style="--tag-color:' + card.tag + ';--tag-tint:' + card.tint + ';">' + escapeHtml(card.macroTag) + '</span>' +
          '</div>' +
          '<div>' + rows + '</div>' +
        '</article>'
      );
    }).join('');
  }

  function renderCallout() {
    calloutEl.style.display = CALLOUT_FILTERS.indexOf(state.filter) !== -1 ? 'flex' : 'none';
  }

  var reducedMotion = false;
  try { reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches; } catch (e) {}

  var io = null;
  var seen = typeof WeakSet !== 'undefined' ? new WeakSet() : null;

  function setupReveal() {
    var nodes = document.querySelectorAll('[data-reveal]');
    if (reducedMotion) {
      nodes.forEach(function (el) { el.classList.add('is-visible'); });
      return;
    }
    if (!io) {
      io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -6% 0px' });
    }
    nodes.forEach(function (el) {
      if (seen && seen.has(el)) return;
      if (seen) seen.add(el);
      io.observe(el);
    });
  }

  function render() {
    renderChips();
    renderCards();
    renderCallout();
    setupReveal();
  }

  document.getElementById('btn-back').addEventListener('click', function () {
    try { history.back(); } catch (e) {}
  });

  document.getElementById('btn-print').addEventListener('click', function () {
    window.print();
  });

  render();
})();
</script>

</body>
</html>
